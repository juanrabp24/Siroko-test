<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Siroko Store</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:        #0a0a0a;
    --surface:   #111111;
    --surface2:  #1a1a1a;
    --border:    #222222;
    --accent:    #f5c518;
    --accent2:   #ff4d1c;
    --text:      #f0f0f0;
    --muted:     #666666;
    --radius:    12px;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    min-height: 100vh;
  }

  /* ── NAV ── */
  nav {
    position: sticky; top: 0; z-index: 100;
    display: flex; align-items: center; justify-content: space-between;
    padding: 0 48px;
    height: 64px;
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 3px;
    color: var(--accent);
  }

  .cart-btn {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 20px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: border-color .2s, background .2s;
  }
  .cart-btn:hover { border-color: var(--accent); background: var(--surface); }

  .cart-count {
    background: var(--accent);
    color: #000;
    font-weight: 500;
    font-size: 12px;
    padding: 2px 7px;
    border-radius: 20px;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 100px 48px 80px;
    overflow: hidden;
  }

  .hero::before {
    content: 'SIROKO TEST';
    position: absolute;
    top: -20px; left: -10px;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 280px;
    color: rgba(245,197,24,0.04);
    pointer-events: none;
    white-space: nowrap;
    line-height: 1;
  }

  .hero h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(56px, 8vw, 100px);
    line-height: .95;
    letter-spacing: 2px;
    max-width: 700px;
  }

  .hero h1 span { color: var(--accent); }

  .hero p {
    margin-top: 20px;
    color: var(--muted);
    font-size: 16px;
    max-width: 400px;
    line-height: 1.6;
  }

  .hero-tags {
    display: flex; gap: 10px; margin-top: 32px; flex-wrap: wrap;
  }

  .tag {
    padding: 6px 14px;
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ── CATALOG SECTION ── */
  .section {
    padding: 60px 48px;
  }

  .section-header {
    display: flex; align-items: baseline; gap: 16px;
    margin-bottom: 36px;
  }

  .section-header h2 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    letter-spacing: 2px;
  }

  .section-header span {
    color: var(--muted);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ── PRODUCT GRID ── */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .product-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color .25s, transform .25s;
    cursor: pointer;
  }

  .product-card:hover {
    border-color: var(--accent);
    transform: translateY(-4px);
  }

  .product-img {
    height: 180px;
    background: var(--surface2);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 64px;
    color: var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }

  .product-img::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, transparent 60%, rgba(245,197,24,0.06));
  }

  .stock-badge {
    position: absolute;
    top: 12px; right: 12px;
    padding: 4px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: .5px;
    text-transform: uppercase;
  }

  .stock-badge.in  { background: rgba(34,197,94,0.15); color: #4ade80; border: 1px solid rgba(74,222,128,0.2); }
  .stock-badge.out { background: rgba(255,77,28,0.15); color: #ff4d1c; border: 1px solid rgba(255,77,28,0.2); }

  .product-body { padding: 20px; }

  .product-name {
    font-weight: 500;
    font-size: 15px;
    margin-bottom: 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-meta {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 4px;
  }

  .product-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 26px;
    color: var(--accent);
    letter-spacing: 1px;
  }

  .product-stock {
    font-size: 12px;
    color: var(--muted);
  }

  .add-btn {
    margin-top: 16px;
    width: 100%;
    padding: 11px;
    background: var(--accent);
    color: #000;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 14px;
    cursor: pointer;
    transition: background .2s, transform .1s;
    letter-spacing: .3px;
  }

  .add-btn:hover { background: #ffd740; }
  .add-btn:active { transform: scale(.98); }
  .add-btn:disabled { background: var(--border); color: var(--muted); cursor: not-allowed; }

  /* ── CART PANEL ── */
  .cart-overlay {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(4px);
    opacity: 0; pointer-events: none;
    transition: opacity .3s;
  }

  .cart-overlay.open { opacity: 1; pointer-events: all; }

  .cart-panel {
    position: fixed;
    top: 0; right: 0; bottom: 0;
    width: 420px;
    background: var(--surface);
    border-left: 1px solid var(--border);
    z-index: 201;
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform .35s cubic-bezier(.4,0,.2,1);
  }

  .cart-overlay.open .cart-panel { transform: translateX(0); }

  .cart-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 28px;
    border-bottom: 1px solid var(--border);
  }

  .cart-header h3 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 24px;
    letter-spacing: 2px;
  }

  .close-btn {
    width: 36px; height: 36px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text);
    cursor: pointer;
    font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    transition: border-color .2s;
  }
  .close-btn:hover { border-color: var(--accent2); color: var(--accent2); }

  .cart-items { flex: 1; overflow-y: auto; padding: 20px 28px; }

  .cart-item {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--border);
    animation: slideIn .2s ease;
  }

  @keyframes slideIn {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .cart-item-icon {
    width: 48px; height: 48px;
    background: var(--surface2);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }

  .cart-item-info { flex: 1; min-width: 0; }

  .cart-item-name {
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cart-item-qty {
    font-size: 12px;
    color: var(--muted);
    margin-top: 3px;
  }

  .cart-item-price {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    color: var(--accent);
    flex-shrink: 0;
  }

  .remove-item {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 16px;
    padding: 4px;
    transition: color .2s;
    flex-shrink: 0;
  }
  .remove-item:hover { color: var(--accent2); }

  .cart-footer {
    padding: 24px 28px;
    border-top: 1px solid var(--border);
  }

  .cart-total {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 20px;
  }

  .cart-total span:first-child {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--muted);
  }

  .cart-total-amount {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 36px;
    color: var(--accent);
  }

  .checkout-btn {
    width: 100%;
    padding: 14px;
    background: var(--accent2);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 500;
    font-size: 15px;
    cursor: pointer;
    letter-spacing: .5px;
    transition: background .2s, transform .1s;
  }

  .checkout-btn:hover { background: #ff6a3d; }
  .checkout-btn:active { transform: scale(.99); }
  .checkout-btn:disabled { background: var(--border); color: var(--muted); cursor: not-allowed; }

  /* ── EMPTY STATES ── */
  .empty {
    display: flex; flex-direction: column; align-items: center;
    padding: 60px 20px;
    color: var(--muted);
    gap: 12px;
    text-align: center;
  }

  .empty-icon { font-size: 48px; opacity: .4; }
  .empty p { font-size: 14px; line-height: 1.6; }

  /* ── TOAST ── */
  .toast-container {
    position: fixed;
    bottom: 28px; right: 28px;
    z-index: 300;
    display: flex; flex-direction: column; gap: 10px;
  }

  .toast {
    padding: 14px 20px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 14px;
    display: flex; align-items: center; gap: 10px;
    animation: toastIn .3s ease;
    max-width: 320px;
    box-shadow: 0 8px 32px rgba(0,0,0,.4);
  }

  .toast.success { border-color: rgba(74,222,128,0.3); }
  .toast.error   { border-color: rgba(255,77,28,0.3); }

  @keyframes toastIn {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── LOADER ── */
  .loader {
    display: flex; align-items: center; justify-content: center;
    padding: 80px;
    color: var(--muted);
    gap: 12px;
    font-size: 14px;
  }

  .spinner {
    width: 20px; height: 20px;
    border: 2px solid var(--border);
    border-top-color: var(--accent);
    border-radius: 50%;
    animation: spin .8s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── SCROLLBAR ── */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
</style>
</head>
<body>

<nav>
  <div class="logo">SIROKO TEST</div>
  <button class="cart-btn" onclick="openCart()">
    <span>🛒 Carrito</span>
    <span class="cart-count" id="cartCount">0</span>
  </button>
</nav>

<section class="hero">
  <h1>EQUÍPATE<br>PARA <span>GANAR</span></h1>
  <p>Ropa técnica de ciclismo y fitness diseñada para rendir al máximo.</p>
  <div class="hero-tags">
    <span class="tag">Ciclismo</span>
    <span class="tag">Fitness</span>
    <span class="tag">Running</span>
    <span class="tag">Triatlón</span>
  </div>
</section>

<section class="section">
  <div class="section-header">
    <h2>Catálogo</h2>
    <span id="productCount">cargando...</span>
  </div>
  <div class="product-grid" id="productGrid">
    <div class="loader"><div class="spinner"></div> Cargando productos</div>
  </div>
</section>

<!-- Cart overlay -->
<div class="cart-overlay" id="cartOverlay" onclick="handleOverlayClick(event)">
  <div class="cart-panel">
    <div class="cart-header">
      <h3>Tu carrito</h3>
      <button class="close-btn" onclick="closeCart()">✕</button>
    </div>
    <div class="cart-items" id="cartItems">
      <div class="empty">
        <div class="empty-icon">🛒</div>
        <p>Tu carrito está vacío.<br>Añade algún producto para empezar.</p>
      </div>
    </div>
    <div class="cart-footer">
      <div class="cart-total">
        <span>Total</span>
        <span class="cart-total-amount" id="cartTotal">0,00 €</span>
      </div>
      <button class="checkout-btn" id="checkoutBtn" onclick="goToCheckout()" disabled>
        Ver resumen y pagar
      </button>
    </div>
  </div>
</div>

<div class="toast-container" id="toastContainer"></div>

<script>
  const API     = '';
  const CART_ID = 'cart-' + Math.random().toString(36).slice(2, 9);
  const USER_ID = 'user-demo';
  const ICONS   = ['🚴', '👕', '🧢', '🩳', '🧤', '👟', '🥽', '🎽'];

  let cartItems = [];

  // ── PRODUCTS ──────────────────────────────────────────────────────────────

  async function loadProducts() {
    try {
      const res = await fetch(`${API}/products`);
      if (!res.ok) throw new Error();
      const products = await res.json();
      renderProducts(products);
    } catch {
      document.getElementById('productGrid').innerHTML = `
        <div class="empty">
          <div class="empty-icon">⚠️</div>
          <p>No se pudieron cargar los productos.<br>
          Asegúrate de que la API está corriendo y hay productos creados.</p>
        </div>`;
      document.getElementById('productCount').textContent = 'error al cargar';
    }
  }

  function renderProducts(products) {
    const grid = document.getElementById('productGrid');
    document.getElementById('productCount').textContent =
      `${products.length} producto${products.length !== 1 ? 's' : ''}`;

    if (!products.length) {
      grid.innerHTML = `
        <div class="empty">
          <div class="empty-icon">📦</div>
          <p>No hay productos todavía.<br>Crea algunos con POST /products</p>
        </div>`;
      return;
    }

    grid.innerHTML = products.map((p, i) => `
      <div class="product-card">
        <div class="product-img">
          ${ICONS[i % ICONS.length]}
          <span class="stock-badge ${p.available ? 'in' : 'out'}">
            ${p.available ? 'En stock' : 'Agotado'}
          </span>
        </div>
        <div class="product-body">
          <div class="product-name">${esc(p.name)}</div>
          <div class="product-meta">
            <span class="product-price">${formatPrice(p.price)}</span>
            <span class="product-stock">${p.stock} uds.</span>
          </div>
          <button
            class="add-btn"
            ${!p.available ? 'disabled' : ''}
            onclick="addToCart('${esc(p.productId)}', '${esc(p.name)}', ${p.price})">
            ${p.available ? '+ Añadir al carrito' : 'Sin stock'}
          </button>
        </div>
      </div>
    `).join('');
  }

  // ── CART ──────────────────────────────────────────────────────────────────

  async function addToCart(productId, productName, productPrice) {
    try {
      const res = await fetch(`${API}/cart/${CART_ID}/items`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          userId: USER_ID,
          productId,
          productName,
          productPrice,
          quantity: 1,
        }),
      });
      if (!res.ok) throw new Error(await res.text());
      await refreshCart();
      toast('✓ Añadido al carrito', 'success');
    } catch (e) {
      toast('Error al añadir el producto', 'error');
    }
  }

  async function removeFromCart(productId) {
    try {
      const res = await fetch(`${API}/cart/${CART_ID}/items/${productId}`, {
        method: 'DELETE',
      });
      if (!res.ok) throw new Error();
      await refreshCart();
      toast('Producto eliminado', 'success');
    } catch {
      toast('Error al eliminar el producto', 'error');
    }
  }

  async function refreshCart() {
    try {
      const res = await fetch(`${API}/cart/${CART_ID}`);
      if (!res.ok) { cartItems = []; updateCartUI([]); return; }
      const data = await res.json();
      cartItems = data.items || [];
      updateCartUI(data);
    } catch {
      cartItems = [];
    }
    updateCartCount();
  }

  function updateCartUI(data) {
    const container = document.getElementById('cartItems');
    const items = data.items || [];

    if (!items.length) {
      container.innerHTML = `
        <div class="empty">
          <div class="empty-icon">🛒</div>
          <p>Tu carrito está vacío.<br>Añade algún producto para empezar.</p>
        </div>`;
      document.getElementById('cartTotal').textContent = '0,00 €';
      document.getElementById('checkoutBtn').disabled = true;
      return;
    }

    container.innerHTML = items.map((item, i) => `
      <div class="cart-item">
        <div class="cart-item-icon">${ICONS[i % ICONS.length]}</div>
        <div class="cart-item-info">
          <div class="cart-item-name">${esc(item.productName)}</div>
          <div class="cart-item-qty">Cantidad: ${item.quantity}</div>
        </div>
        <span class="cart-item-price">${formatPrice(item.total)}</span>
        <button class="remove-item" onclick="removeFromCart('${esc(item.productId)}')">✕</button>
      </div>
    `).join('');

    document.getElementById('cartTotal').textContent = formatPrice(data.total || 0);
    document.getElementById('checkoutBtn').disabled = false;
    updateCartCount();
  }

  function updateCartCount() {
    const total = cartItems.reduce((s, i) => s + i.quantity, 0);
    document.getElementById('cartCount').textContent = total;
  }

  function goToCheckout() {
    window.location.href = `/checkout?cartId=${CART_ID}`;
  }

  // ── CART PANEL ────────────────────────────────────────────────────────────

  function openCart() {
    refreshCart();
    document.getElementById('cartOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    document.getElementById('cartOverlay').classList.remove('open');
    document.body.style.overflow = '';
  }

  function handleOverlayClick(e) {
    if (e.target === document.getElementById('cartOverlay')) closeCart();
  }

  // ── UTILS ─────────────────────────────────────────────────────────────────

  function formatPrice(cents) {
    return (cents / 100).toLocaleString('es-ES', {
      style: 'currency', currency: 'EUR',
    });
  }

  function esc(str) {
    return String(str)
      .replace(/&/g,'&amp;').replace(/</g,'&lt;')
      .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function toast(msg, type = 'success') {
    const c = document.getElementById('toastContainer');
    const t = document.createElement('div');
    t.className = `toast ${type}`;
    t.textContent = msg;
    c.appendChild(t);
    setTimeout(() => t.remove(), 3000);
  }

  // ── INIT ──────────────────────────────────────────────────────────────────
  loadProducts();
</script>
</body>
</html>
