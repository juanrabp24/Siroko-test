# Copia este fichero a .env y ajusta los valores según tu entorno.
# El fichero .env real nunca se sube a git.

APP_ENV=dev
APP_SECRET=cambia_esto_por_un_secreto_aleatorio
DEFAULT_URI=http://localhost

# Credenciales MySQL — deben coincidir con las del servicio 'database' en docker-compose.yml
DATABASE_URL="mysql://symfony:symfony@database:3306/symfony?serverVersion=8.4&charset=utf8mb4"
